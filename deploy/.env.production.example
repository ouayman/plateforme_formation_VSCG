# Copier vers /opt/vsc-platform/.env sur le VPS

APP_URL=https://formation.valuestream-consulting.com
NODE_ENV=production
PORT=3000
NODE_OPTIONS=--max-old-space-size=512
DEMO_MODE=false

# Générer : openssl rand -base64 32
JWT_SECRET=change-me-generate-a-long-random-secret

# PostgreSQL local — limiter les connexions Prisma sur petit VPS
DATABASE_URL=postgresql://vscg:change-me-db-password@localhost:5432/vsc_platform?schema=public&connection_limit=5

# IONOS SMTP — port 465 (SSL)
SMTP_HOST=smtp.ionos.fr
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=formation@valuestream-consulting.com
SMTP_PASS=change-me-ionos-smtp-password
SMTP_FROM="Value Stream Consulting <formation@valuestream-consulting.com>"
SMTP_REPLY_TO=formation@valuestream-consulting.com

# Fallback STARTTLS :
# SMTP_PORT=587
# SMTP_SECURE=false

# Backup script (optionnel)
DB_USER=vscg
DB_NAME=vsc_platform
