# PostgreSQL (service Docker `db`)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_DB=vsc_platform

# App
APP_PORT=3000
APP_URL=http://localhost:3000
JWT_SECRET=change-me-min-32-chars
DEMO_MODE=true
# Connexion rapide sans OTP (login + switch user). Vercel : variable DEMO_MODE, Preview=true, Production=false

# DATABASE_URL est construit automatiquement dans docker-compose.yml
#
# Vercel + Neon — une seule variable DATABASE_URL (URL pooler recommandée) :
# DATABASE_URL=postgresql://user:pass@ep-xxx-pooler.eu-central-1.aws.neon.tech/neondb?sslmode=require&pgbouncer=true&connect_timeout=15&connection_limit=1
#
# Copie local → Neon (npm run db:copy)
# LOCAL_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/vsc_platform
# REMOTE_DATABASE_URL=postgresql://user:pass@host/neondb?sslmode=require
#
# Build Docker : DOCKER_BUILD=1 (standalone) — défini dans le Dockerfile ; Vercel n'utilise pas standalone.
#
# Stockage fichiers (Vercel Blob ou disque local ./uploads)
# STORAGE_BACKEND=blob|local  (auto : blob si VERCEL ou BLOB_READ_WRITE_TOKEN)
# STORAGE_ENV=development     (optionnel ; défaut VERCEL_ENV ou development)
# BLOB_READ_WRITE_TOKEN=      (local : vercel env pull)
#
# Prisma — diagnostic requêtes (dev : activé par défaut)
# LOG_PRISMA_QUERIES=true
# LOG_PRISMA_ALL=true
# LOG_PRISMA_SQL=true
# PRISMA_WARN_MS=300
# PRISMA_SLOW_MS=1000
#
# Dev — file watcher (défaut : polling si chemin OneDrive, sinon watcher natif)
# WEBPACK_POLL=true
# WEBPACK_POLL=false
# WEBPACK_POLL_INTERVAL=1000

# --- Local + Mailpit (`docker compose --profile dev up`) ---
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Value Stream Consulting <noreply@localhost>"
SMTP_REPLY_TO=

