# PostgreSQL (service Docker `db`)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_DB=vsc_platform

# App
APP_PORT=3000
APP_URL=http://localhost:3000
JWT_SECRET=change-me-min-32-chars
DEMO_MODE=true
# Connexion rapide sans OTP (login + switch user). Vercel : variable DEMO_MODE, Preview=true, Production=false

# DATABASE_URL est construit automatiquement dans docker-compose.yml

# --- Local + Mailpit (`docker compose --profile dev up`) ---
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Value Stream Consulting <noreply@localhost>"
SMTP_REPLY_TO=

